class Logger private constructor(internal val handle: Long) : AutoCloseable {
    private val closed = AtomicBoolean(false)

    override fun close() {
        if (!closed.compareAndSet(false, true)) return
        Native.riff_logger_free(handle)
    }

    companion object {

        fun getDefault(): Logger = Logger(Native.riff_logger_get_default())
    }
}
