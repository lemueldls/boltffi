---
source: riff_bindgen/src/render/kotlin/templates.rs
expression: template.render().unwrap()
---
fun greet(name: String): String {
    val nameWire = WireWriterPool.acquire(RiffWire.sizeString(name))
    try {
        run {
            val wire = nameWire.writer
            RiffWire.writeString(name)
        }
        val buf = Native.riff_greet(nameWire.ptr, nameWire.len)
            ?: throw FfiException(-1, "Null buffer returned")
        val reader = WireReader(buf)
        return reader.readString()
    } finally {
        nameWire.close().close()
    }
}
