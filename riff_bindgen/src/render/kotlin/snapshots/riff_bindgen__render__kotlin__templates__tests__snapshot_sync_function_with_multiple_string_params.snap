---
source: riff_bindgen/src/render/kotlin/templates.rs
expression: template.render().unwrap()
---
fun concat(a: String, b: String): String {
    val aWire = WireWriterPool.acquire(RiffWire.sizeString(a))
    val bWire = WireWriterPool.acquire(RiffWire.sizeString(b))
    try {
        run {
            val wire = aWire.writer
            RiffWire.writeString(a)
        }
        run {
            val wire = bWire.writer
            RiffWire.writeString(b)
        }
        val buf = Native.riff_concat(aWire.ptr, aWire.len, bWire.ptr, bWire.len)
            ?: throw FfiException(-1, "Null buffer returned")
        val reader = WireReader(buf)
        return reader.readString()
    } finally {
        aWire.close().close()
        bWire.close().close()
    }
}
