---
import CodeComparison from './CodeComparison';

interface Props {
  rust: string;
  swift: string;
  kotlin: string;
  title?: string;
}

const { rust, swift, kotlin, title } = Astro.props;
---

<CodeComparison 
  rust={rust} 
  swift={swift} 
  kotlin={kotlin} 
  title={title} 
  client:load 
/>
