---
import BaseLayout from './BaseLayout.astro';
import DocsHeader from '../components/DocsHeader.astro';
import Sidebar from '../components/Sidebar';

interface Props {
  title: string;
  description?: string;
  activeSection: string;
}

const { title, description, activeSection } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-background">
    <DocsHeader />
    <div class="max-w-7xl mx-auto flex">
      <Sidebar activeSection={activeSection} client:load />
      <main class="flex-1 min-w-0 py-10 px-6 lg:px-12">
        <article class="animate-fade-in prose prose-invert prose-headings:text-foreground prose-p:text-muted-foreground prose-a:text-primary prose-strong:text-foreground prose-code:before:content-none prose-code:after:content-none prose-code:border-0 prose-pre:bg-[hsl(var(--code-bg))] prose-pre:border prose-pre:border-border max-w-none">
          <slot />
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
