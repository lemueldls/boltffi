    /**
     * Recursive addition node.
     */
    data class Add(val left: ExprTree, val right: ExprTree) : ExprTree()
}

fun ExprTree.wireEncodedSize(): Int = 4 + when (this) {
    is ExprTree.Value -> 4
    is ExprTree.Add -> left.wireEncodedSize() + right.wireEncodedSize()
}

fun ExprTree.wireEncodeTo(wire: boltffiWireWriter) {
    when (this) {
        is ExprTree.Value -> {
            wire.writeI32(0)
            wire.writeI32(value)
        }
        is ExprTree.Add -> {
            wire.writeI32(1)
            left.wireEncodeTo(wire)
            right.wireEncodeTo(wire)
        }
    }
}
