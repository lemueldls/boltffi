// Generated by BoltFFI. Do not edit.
/**
 * A recursive tree node.
 */
data class TreeNode(
    val value: Int,
    val next: TreeNode? = null
)
fun TreeNode.wireEncodedSize(): Int = 4 + 1 + (next?.wireEncodedSize() ?: 0)

fun TreeNode.wireEncodeTo(wire: boltffiWireWriter) {
    wire.writeI32(value)
    if (next == null) {
        wire.writeU8(0u)
    } else {
        wire.writeU8(1u)
        next.wireEncodeTo(wire)
    }
}
