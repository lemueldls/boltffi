// Generated by BoltFFI. Do not edit.
/**
 * Current status.
 */

enum class Status(val value: Int) {
    /**
     * No work in progress.
     */
    Idle(0),
    /**
     * Work is in progress.
     */
    Running(1);
}

fun Status.wireEncodedSize(): Int = 4

fun Status.wireEncodeTo(wire: boltffiWireWriter) {
    wire.writeI32(this.value)
}
